{
  "_comment": "这是一个配置模板文件 - OpenClaw 会提示用户上传完整配置文件",
  "config_version": "1.0.0",
  
  "schedule": {
    "check_interval_days": 5,
    "update_deadline_days": 7,
    "preferred_time_utc": "23:45"
  },
  
  "paths": {
    "memory_dir": "/home/node/.openclaw/workspace/memory",
    "daily_notes_pattern": "%Y-%m-%d.md",
    "longterm_file": "MEMORY.md"
  },
  
  "preferences": {
    "language": "zh-CN",
    "use_emoji": true,
    "include_timestamps": true,
    "auto_commit_to_memory": true
  }
}